# Access4All — Vite app environment variables
# Copy to app/.env.local and fill in your Supabase project values.

# ---------------------------------------------------------------------------
# Supabase (required for live data + community reports)
# Dashboard → Project Settings → API
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: service role — NEVER expose in client builds; server/scripts only
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Optional portfolio API override (defaults to /portfolio/access4all on restarto.ai)
# ---------------------------------------------------------------------------
# VITE_API_BASE=

# ---------------------------------------------------------------------------
# Monad blockchain (on-chain verification badges + transaction history)
# Testnet RPC: https://testnet-rpc.monad.xyz · Chain ID 10143
# Deploy AccessLinkVerified.sol then set contract address below.
# ---------------------------------------------------------------------------
# VITE_MONAD_RPC=https://testnet-rpc.monad.xyz
# VITE_CONTRACT_ADDRESS=0xYourDeployedContract

# Server-only (Vercel env — never expose in client):
# MONAD_PRIVATE_KEY=your-deployer-or-verifier-wallet-key
# MONAD_RPC_URL=https://testnet-rpc.monad.xyz
# Sign up at https://accessibility.cloud → create org → add app → copy app token
# ---------------------------------------------------------------------------
# VITE_ACCESSIBILITY_CLOUD_TOKEN=your-app-token

# ---------------------------------------------------------------------------
# Optional Mapbox (production map tiles — client uses OSM embed until set)
# ---------------------------------------------------------------------------
# VITE_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# ---------------------------------------------------------------------------
# Optional Google Maps (production embed — links work without a key)
# ---------------------------------------------------------------------------
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-key
